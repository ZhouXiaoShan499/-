# ========== 1. 全局换行符统一规则（解决LF/CRLF警告，核心配置） ==========
# 所有文本文件自动识别，统一使用LF换行符（跨平台兼容，Windows/macOS/Linux通用）
* text=auto eol=lf

# 明确指定高频文本文件的换行符规则
*.txt text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# ========== 2. Git LFS 大文件托管规则（保留并完善你的原有配置） ==========
# 模型二进制文件，交给LFS管理，标记为二进制不做文本处理
*.onnx filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text

# 大文件目录全量LFS管理，补充覆盖你public下的模型目录
data/** filter=lfs diff=lfs merge=lfs -text
models/** filter=lfs diff=lfs merge=lfs -text
public/models/** filter=lfs diff=lfs merge=lfs -text

# 硬件ECAD文件
hw/pcb/*.sch filter=lfs diff=lfs merge=lfs -text
hw/pcb/*.brd filter=lfs diff=lfs merge=lfs -text